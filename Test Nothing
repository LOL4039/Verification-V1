    Library.Unload = function(self)
        for _, BlurData in self.BlurElements do
            pcall(function() BlurData.Part.Instance:Destroy() end)
            pcall(function() BlurData.DepthOfField.Instance:Destroy() end)
        end

        for Index, Value in self.Connections do 
            Value.Connection:Disconnect()
        end

        for Index, Value in self.Threads do 
            pcall(function()
                if type(Value) == "thread" then
                    task.cancel(Value)
                end
            end)
        end

        if self.Holder then 
            self.Holder:Clean()
        end

        Library = nil 
        getgenv().Library = nil
    end

