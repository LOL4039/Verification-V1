                -- Groq AI search helper
                local function GroqSearch(Query)
                    if not Window.GroqKey or Window.GroqKey == "" then
                        SearchElements(Query)
                        return
                    end

                    Library:Thread(function()
                        -- Collect all element names
                        local AllNames = {}
                        for _, Page in ipairs(Window.Pages) do
                            for _, Section in pairs(Page.Sections or {}) do
                                for _, Element in ipairs(Section.Elements or {}) do
                                    if Element.Name and Element.Name ~= "" then
                                        TableInsert(AllNames, Element.Name)
                                    end
                                end
                            end
                        end

                        local Success, Response = pcall(function()
                            local HttpService = game:GetService("HttpService")
                            local Body = HttpService:JSONEncode({
                                model = "llama-3.1-8b-instant",
                                messages = {
                                    {role = "system", content = "You are a search helper. Given a user query and a list of UI element names, return ONLY the matching element names as a JSON array. Match partial names, synonyms, and related terms. Return only the JSON array, nothing else."},
                                    {role = "user", content = "Query: \"" .. Query .. "\"\nElements: " .. HttpService:JSONEncode(AllNames)}
                                },
                                max_tokens = 200,
                                temperature = 0.1
                            })

                            local Resp = request({
                                Url = "https://api.groq.com/openai/v1/chat/completions",
                                Method = "POST",
                                Headers = {
                                    ["Content-Type"] = "application/json",
                                    ["Authorization"] = "Bearer " .. Window.GroqKey
                                },
                                Body = Body
                            })

                            if Resp and Resp.Body then
                                local Data = HttpService:JSONDecode(Resp.Body)
                                if Data.choices and Data.choices[1] then
                                    local Content = Data.choices[1].message.content
                                    local Matched = HttpService:JSONDecode(Content)
                                    return Matched
                                end
                            end
                            return nil
                        end)

                        if Success and Response and type(Response) == "table" then
                            -- Clear results
                            for _, Child in ipairs(Items["SearchResults"].Instance:GetChildren()) do
                                if not Child:IsA("UIListLayout") then Child:Destroy() end
                            end

                            -- Find elements matching AI response
                            local AIQuery = ""
                            for _, Name in ipairs(Response) do
                                AIQuery = AIQuery .. Name .. "|"
                            end

                            for _, Page in ipairs(Window.Pages) do
                                for _, Section in pairs(Page.Sections or {}) do
                                    for _, Element in ipairs(Section.Elements or {}) do
                                        local ElemName = Element.Name or ""
                                        for _, MatchName in ipairs(Response) do
                                            if string.lower(ElemName) == string.lower(MatchName) then
                                                local ResultBtn = Instance.new("TextButton")
                                                ResultBtn.Parent = Items["SearchResults"].Instance
                                                ResultBtn.FontFace = Library.Font
                                                ResultBtn.TextColor3 = FromRGB(240, 240, 240)
                                                ResultBtn.TextTransparency = 0.2
                                                ResultBtn.Text = "  " .. ElemName
                                                ResultBtn.TextXAlignment = Enum.TextXAlignment.Left
                                                ResultBtn.AutoButtonColor = false
                                                ResultBtn.Size = UDim2New(1, 0, 0, 34)
                                                ResultBtn.BackgroundTransparency = 0.6
                                                ResultBtn.BackgroundColor3 = FromRGB(20, 20, 23)
                                                ResultBtn.BorderSizePixel = 0
                                                ResultBtn.ZIndex = 52
                                                ResultBtn.TextSize = 13

                                                local Corner = Instance.new("UICorner")
                                                Corner.CornerRadius = UDimNew(0, 6)
                                                Corner.Parent = ResultBtn

                                                local SubLabel = Instance.new("TextLabel")
                                                SubLabel.Parent = ResultBtn
                                                SubLabel.FontFace = Library.Fonts["Light"]
                                                SubLabel.TextColor3 = FromRGB(120, 120, 125)
                                                SubLabel.Text = (Page.Name or "Page") .. " > " .. (Section.Name or "Section") .. "  AI"
                                                SubLabel.Size = UDim2New(0.5, -10, 1, 0)
                                                SubLabel.Position = UDim2New(0.5, 5, 0, 0)
                                                SubLabel.BackgroundTransparency = 1
                                                SubLabel.BorderSizePixel = 0
                                                SubLabel.ZIndex = 52
                                                SubLabel.TextSize = 10
                                                SubLabel.TextXAlignment = Enum.TextXAlignment.Right

                                                ResultBtn.MouseButton1Click:Connect(function()
                                                    for PageIdx, P in ipairs(Window.Pages) do
                                                        if P == Page then
                                                            Window:SelectTab(PageIdx)
                                                            break
                                                        end
