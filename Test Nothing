                            local HttpService = game:GetService("HttpService")

                            local UIInfo = "none"
                            pcall(function()
                                UIInfo = HttpService:JSONEncode(Window._UIContext or {})
                            end)

                            local SystemPrompt = "You are a friendly AI assistant embedded in a Roblox script UI called '" .. (Window.Name or "Hub") .. "' for the game '" .. (Window._GameName or "Unknown") .. "'. "
                                .. "You can have friendly conversations, help explain what each setting/feature in this UI does, give tips and strategies for the game, and answer questions about how the script works. "
