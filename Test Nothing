                                print("✅ Server Verified: " .. (name or "Unknown"))
                                print("🆔 Correct ID: " .. (data.guild.id or "N/A"))
                                print("🟢 Online: " .. online)
                                print("👥 Totals: " .. total)
                                print("--------------------------------")
                            end
                        end
