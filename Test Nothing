                            end
                        else
                            -- Fallback to basic search
                            SearchElements(Query)
                        end
                    end)
                end

                -- Debounce search
                local SearchDebounce = nil
                Items["SearchInput"]:Connect("Changed", function(Prop)
                    if Prop ~= "Text" then return end
                    local Query = Items["SearchInput"].Instance.Text
                    if SearchDebounce then
